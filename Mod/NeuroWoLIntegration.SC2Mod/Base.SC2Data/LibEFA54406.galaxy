include "TriggerLibs/NativeLib"

include "LibEFA54406_h"

//--------------------------------------------------------------------------------------------------
// Library: NeuroLib
//--------------------------------------------------------------------------------------------------
// External Library Initialization
void libEFA54406_InitLibraries () {
    libNtve_InitVariables();
}

// Variable Initialization
bool libEFA54406_InitVariables_completed = false;

void libEFA54406_InitVariables () {
    if (libEFA54406_InitVariables_completed) {
        return;
    }

    libEFA54406_InitVariables_completed = true;

    libEFA54406_gv_bankwriteallowed = true;
}

// Functions
void libEFA54406_gf_create_action_0_arg (string lp_action_name, bool lp_action_active, string lp_action_description, int lp_action_uses) {
    // Automatic Variable Declarations
    // Implementation
    while ((libEFA54406_gv_bankwriteallowed == false)) {
        Wait(0.01, c_timeGame);
    }
    libEFA54406_gv_bankwriteallowed = false;
    BankLoad("NeuroIntegration", 1);
    BankWait(BankLastCreated());
    BankValueSetFromFlag(BankLastCreated(), "possible_actions", (lp_action_name + "_active"), lp_action_active);
    BankValueSetFromString(BankLastCreated(), "possible_actions", (lp_action_name + "_description"), lp_action_description);
    BankValueSetFromInt(BankLastCreated(), "possible_actions", (lp_action_name + "_uses"), lp_action_uses);
    BankSave(BankLastCreated());
    libEFA54406_gv_bankwriteallowed = true;
}

