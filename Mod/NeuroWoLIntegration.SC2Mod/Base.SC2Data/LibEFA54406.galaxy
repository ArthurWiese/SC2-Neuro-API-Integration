}

//--------------------------------------------------------------------------------------------------
void libEFA54406_gt_ClearQueue_Init () {
    libEFA54406_gt_ClearQueue = TriggerCreate("libEFA54406_gt_ClearQueue_Func");
}

void libEFA54406_InitTriggers () {
    libEFA54406_gt_Playerchatmessage_Init();
    libEFA54406_gt_DisableAchievementsCheats_Init();
    libEFA54406_gt_CreateNeuroIntegrationbank_Init();
    libEFA54406_gt_CleanNeuroIntegrationbank_Init();
    libEFA54406_gt_BlockCommands_Init();
    libEFA54406_gt_ClearQueue_Init();
}

//--------------------------------------------------------------------------------------------------
// Library Initialization
//--------------------------------------------------------------------------------------------------
bool libEFA54406_InitLib_completed = false;

void libEFA54406_InitLib () {
    if (libEFA54406_InitLib_completed) {
        return;
    }

    libEFA54406_InitLib_completed = true;

    libEFA54406_InitLibraries();
    libEFA54406_InitVariables();
    libEFA54406_InitTriggers();
}

